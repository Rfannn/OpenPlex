# =============================================================================
# Media Gallery Server — Environment Configuration
# Copy this file to .env and fill in the required values.
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8185
DEBUG=false

# ── Security (REQUIRED) ──────────────────────────────────────────────────────
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# CORS origins (comma-separated). Use "*" for LAN, or specify your domain.
# Example: http://192.168.1.200:8185,http://media-server.home.dns:8185
CORS_ORIGINS=*

# ── Media Root (REQUIRED) ────────────────────────────────────────────────────
# Path to the directory containing your media files
MEDIA_ROOT=/mnt/hdd/media

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/media_gallery.db

# ── Downloads (aria2) ───────────────────────────────────────────────────────
ARIA2_RPC_PORT=6801

# ── Catalog ──────────────────────────────────────────────────────────────────
CATALOG_AUTO_REFRESH=false
CATALOG_REFRESH_INTERVAL_HOURS=24

# ── Thumbnail Cache ─────────────────────────────────────────────────────────
THUMBNAIL_CACHE_DIR=./thumbnails

# ── Disk Space ───────────────────────────────────────────────────────────────
# Minimum free bytes required before allowing downloads (default: 500MB)
MIN_DISK_FREE_BYTES=500000000

# ── AI Chat (Agnes AI — primary) ─────────────────────────────────────────────
# Agnes AI is the primary chat/recommendation engine
# Get your API key at: https://agnes-ai.com
AGNES_API_KEY=
AGNES_MODEL=agnes-2.0-flash

# ── Local AI (llama-server — fallback) ───────────────────────────────────────
# Only started on-demand when Agnes is down or rate-limited
LOCAL_AI_URL=http://127.0.0.1:8081
LOCAL_AI_MODEL=qwen2.5-3b
LOCAL_AI_AUTO_START=false

# ── TMDB (optional — primary metadata source) ────────────────────────────────
# Get free at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── OMDb (optional — backup metadata) ────────────────────────────────────────
# Get free at: http://www.omdbapi.com/apikey.aspx (1000 requests/day)
OMDB_API_KEY=

# ── Fanart.tv (optional — high-res artwork) ──────────────────────────────────
# Get free at: https://fanart.tv/get-an-api-key/
FANART_API_KEY=

# ── TVDb (optional — enhanced TV metadata) ───────────────────────────────────
# Get at: https://thetvdb.com/api-information
TVDB_API_KEY=

# ── OpenSubtitles (optional — auto subtitle fetching) ────────────────────────
# Register at: https://www.opensubtitles.com/en/users/sign_up
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
OPENSUBTITLES_API_KEY=
